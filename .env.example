PROJECT_NAME=Avatar Backend
API_VERSION=0.1.0
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://avatar:avatar@postgres:5432/avatar
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
STORAGE_ROOT=storage
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=avatar_minio
S3_SECRET_ACCESS_KEY=avatar_minio_secret
S3_BUCKET_NAME=avatar
S3_REGION_NAME=us-east-1
S3_SECURE=false
MAX_IMAGE_SIZE_MB=5
MAX_IMAGE_WIDTH=2048
MAX_IMAGE_HEIGHT=2048
MAX_ACTIVE_JOBS_PER_USER=1
ACTIVE_JOB_LOCK_TTL_SECONDS=600
MAX_GLOBAL_ACTIVE_JOBS=100
GLOBAL_QUEUE_RETRY_AFTER_SECONDS=15
ALGORITHM_MODE=mock
ALGORITHM_VERSION=avatar-algo-0.1.0
ASSET_LIBRARY_VERSION=avatar-assets-2026-05
RESULT_SCHEMA_VERSION=1.0
JOB_TIMEOUT_SECONDS=300
MOCK_ALGORITHM_DELAY_SECONDS=10
MOCK_HUMAN_INFO_PATH=examples/HumanInfo(102).json
FACEVERSE_V4_ROOT=FaceVerse_v4
FACEVERSE_V4_DEVICE=auto
FACEVERSE_V4_ALLOW_CPU_FALLBACK=false
FACEVERSE_V4_COMPUTE_VERTICES=true
JOB_HEARTBEAT_TIMEOUT_SECONDS=420
CELERY_TASK_DEFAULT_QUEUE=avatar_default
CELERY_GPU_QUEUE=avatar_gpu
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=20
CELERY_BROKER_VISIBILITY_TIMEOUT_SECONDS=600
WORKER_CONCURRENCY=4
OUTBOX_DISPATCH_INTERVAL_SECONDS=1
OUTBOX_DISPATCH_BATCH_SIZE=50
OUTBOX_RETRY_DELAY_SECONDS=30
OUTBOX_LOCK_TIMEOUT_SECONDS=300
QUEUED_JOB_REDISPATCH_AFTER_SECONDS=600
